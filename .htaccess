Options -Indexes
RewriteEngine On

# Force HTTPS (keep localhost/dev reachable in HTTP)
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1)(:\d+)?$ [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L,NE]

RewriteRule ^(?:app|config|pages|schema|tests|tools|vendor|storage/auth|storage/cache|storage/private)(?:/|$) - [F,L,NC]
RewriteRule (^|/)\.(?!well-known/) - [F,L]
<FilesMatch "^(?:README\.txt|ANALYSE_CRITIQUE_.*\.md|RAPPORT_SECURITE_.*\.md)$">
    Require all denied
</FilesMatch>
<FilesMatch "\.(?:sql|log|bak|dist)$">
    Require all denied
</FilesMatch>

RewriteRule ^sitemap\.xml$ index.php?route=sitemap.xml [L,QSA]
RewriteRule ^robots\.txt$ index.php?route=robots.txt [L,QSA]
RewriteRule ^llms\.txt$ index.php?route=llms.txt [L,QSA]
RewriteRule ^ai-index\.json$ index.php?route=ai-index.json [L,QSA]
RewriteRule ^knowledge-graph\.jsonld$ index.php?route=knowledge-graph.jsonld [L,QSA]
RewriteRule ^index\.php$ - [L]

<IfModule mod_setenvif.c>
    SetEnvIfNoCase Request_URI "(^|/)assets/" on4crd_static_asset
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(?:css|js|mjs|svg|png|jpe?g|webp|gif|woff2?)$">
        Header set Cache-Control "public, max-age=31536000, immutable" env=on4crd_static_asset
    </FilesMatch>
    <FilesMatch "\.(?:webmanifest)$">
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript text/javascript application/json application/manifest+json image/svg+xml
</IfModule>

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^$ index.php [L,QSA]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)$ index.php?route=$1 [L,QSA]
