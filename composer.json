{
  "name": "smartappli/on4crd",
  "description": "Site club ON4CRD en PHP avec modules contenus, QSL, boutique et encheres.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "delight-im/auth": "^9.0",
    "theodo-group/llphant": "^0.11.21"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.1",
    "phpstan/phpstan": "^2.2"
  },
  "scripts": {
    "lint": "php tools/lint.php",
    "duplication": "php tools/check_duplication.php --threshold=3",
    "test": "@php vendor/bin/phpunit --configuration phpunit.xml.dist --testdox"
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
